---
// Pinnasberg 70, 20359 Hamburg - Kocaman Elektrotechnik
const mapSrc = "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2369.8!2d9.9224079!3d53.5529446!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47b18f70c02bf933%3A0xf117aa743054171e!2sKocaman%20Elektrotechnik!5e0!3m2!1sde!2sde!4v1700000000000!5m2!1sde!2sde";
---

<section class="maps" aria-label="Standort Kocaman Elektrotechnik Hamburg">
  <div class="container maps__inner">
    <div class="maps__info">
      <p class="section-label">Standort</p>
      <h2 class="maps__h2">Wir sind in Hamburg vor Ort</h2>
      <p class="maps__text">
        Kocaman Elektrotechnik<br />
        Pinnasberg 70<br />
        20359 Hamburg – Altona-Altstadt
      </p>
      <p class="maps__text">Einsatzgebiet: Hamburg & gesamte Umgebung</p>
    </div>
    <div class="maps__embed">
      <iframe
        src={mapSrc}
        width="100%"
        height="350"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Kocaman Elektrotechnik auf Google Maps – Pinnasberg 70, Hamburg"
        aria-label="Google Maps Karte: Kocaman Elektrotechnik in Hamburg"
      ></iframe>
    </div>
  </div>
</section>

<style>
  .maps {
    padding: var(--section-pad);
    background: var(--color-bg-soft);
  }

  .maps__inner {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 3rem;
    align-items: center;
  }

  .maps__h2 {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--color-primary);
    margin: 0.5rem 0 1rem;
    line-height: 1.3;
  }

  .maps__text {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: 0.75rem;
  }

  .maps__embed {
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    border: 1px solid var(--color-border);
  }

  .maps__embed iframe {
    display: block;
  }

  @media (max-width: 768px) {
    .maps__inner {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
