---
import { business } from "../../data/business";
import { services } from "../../data/services";
---

<section class="kontakt" id="kontakt">
  <div class="container">
    <div class="kontakt__header">
      <p class="section-label">Kontakt</p>
      <h2 class="kontakt__h2">Jetzt Termin vereinbaren</h2>
      <p class="kontakt__sub">24 Stunden täglich für Sie erreichbar.</p>
    </div>

    <div class="kontakt__inner">
      <!-- Info -->
      <div class="kontakt__info">
        <p class="kontakt__intro">
          Wir sind Ihr zuverlässiger Partner für alle {business.brancheArbeiten} in {business.adresse.stadt} und Umgebung. Füllen Sie das Formular aus – wir melden uns innerhalb von 24h zurück.
        </p>

        <div class="kontakt__preishinweis">
          <span class="kontakt__preis-icon">✅</span>
          <div>
            <strong>Kostenloser Kostenvoranschlag</strong>
            <p>Kein Risiko. Wir besichtigen Ihr Projekt und geben Ihnen ein transparentes Angebot – unverbindlich und ohne versteckte Kosten.</p>
          </div>
        </div>

        <div class="kontakt__blocks">
          <div class="kontakt__block">
            <span class="kontakt__block-icon">📞</span>
            <div>
              <p class="kontakt__block-title">
                <a href={business.kontakt.telefonHref}>{business.kontakt.telefon}</a>
              </p>
              <p class="kontakt__block-note">Mo–So, 24h erreichbar</p>
            </div>
          </div>
          <div class="kontakt__block">
            <span class="kontakt__block-icon">✉️</span>
            <div>
              <p class="kontakt__block-title">
                <a href={business.kontakt.emailHref}>{business.kontakt.email}</a>
              </p>
              <p class="kontakt__block-note">Antwort innerhalb 24h</p>
            </div>
          </div>
          <div class="kontakt__block">
            <span class="kontakt__block-icon">📍</span>
            <div>
              <p class="kontakt__block-title">{business.einsatzgebiet}</p>
              <p class="kontakt__block-note">Einsatzgebiet Region {business.adresse.stadt}</p>
            </div>
          </div>
        </div>

        <div class="kontakt__direct">
          <a href={business.kontakt.telefonHref} class="btn btn-primary">
            📞 Jetzt anrufen
          </a>
          <a href={business.kontakt.emailHref} class="btn btn-outline">
            ✉️ E-Mail schreiben
          </a>
        </div>
      </div>

      <!-- Form -->
      <form class="kontakt__form" name="kontakt" method="POST" action="/danke/">
        <div class="form-group">
          <label for="name">Name <span class="required">*</span></label>
          <input type="text" id="name" name="name" required placeholder="Ihr vollständiger Name" />
        </div>

        <div class="form-group">
          <label for="telefon">Telefon</label>
          <input type="tel" id="telefon" name="telefon" placeholder="Ihre Telefonnummer" />
        </div>

        <div class="form-group">
          <label for="email">E-Mail <span class="required">*</span></label>
          <input type="email" id="email" name="email" required placeholder="ihre@email.de" />
        </div>

        <div class="form-group">
          <label for="leistung">Worum geht's?</label>
          <select id="leistung" name="leistung">
            <option value="">Bitte auswählen (optional)</option>
            {services.map((s) => (
              <option value={s.name}>{s.name}</option>
            ))}
            <option value="Sonstiges">Sonstiges</option>
          </select>
        </div>

        <div class="form-group">
          <label for="nachricht">Nachricht <span class="required">*</span></label>
          <textarea id="nachricht" name="nachricht" required rows="5" placeholder="Beschreiben Sie kurz Ihr Anliegen..."></textarea>
        </div>

        <button type="submit" class="btn btn-primary kontakt__submit">
          Anfrage senden
        </button>
      </form>
    </div>
  </div>
</section>

<style>
  .kontakt {
    padding: var(--section-pad);
    background: var(--color-bg);
  }

  .kontakt__header {
    text-align: center;
    max-width: 560px;
    margin: 0 auto 3rem;
  }

  .kontakt__h2 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    color: var(--color-primary);
    margin: 0.5rem 0 1rem;
    line-height: 1.25;
  }

  .kontakt__sub {
    color: var(--color-text-muted);
    font-size: 1rem;
  }

  .kontakt__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .kontakt__intro {
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }

  .kontakt__preishinweis {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    background: #f0f9f4;
    border: 1px solid #b8e0c8;
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    margin-bottom: 1.75rem;
  }

  .kontakt__preis-icon {
    font-size: 1.2rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .kontakt__preishinweis strong {
    display: block;
    font-size: 0.9rem;
    color: #1a5c35;
    margin-bottom: 0.25rem;
  }

  .kontakt__preishinweis p {
    font-size: 0.82rem;
    color: #2d7a4f;
    line-height: 1.6;
    margin: 0;
  }

  .kontakt__blocks {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .kontakt__block {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .kontakt__block-icon {
    font-size: 1.5rem;
    width: 2.5rem;
    flex-shrink: 0;
  }

  .kontakt__block-title {
    font-weight: 700;
    color: var(--color-primary);
    font-size: 0.95rem;
  }

  .kontakt__block-title a {
    color: inherit;
    transition: color 0.2s;
  }

  .kontakt__block-title a:hover {
    color: var(--color-accent);
  }

  .kontakt__block-note {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-top: 0.15rem;
  }

  .kontakt__direct {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .kontakt__form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    background: var(--color-bg-soft);
    padding: 2.5rem;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-group label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .required {
    color: var(--color-accent);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 0.75rem 1rem;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    font-family: var(--font-body);
    color: var(--color-text);
    background: white;
    transition: border-color 0.2s;
    outline: none;
    width: 100%;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(26, 58, 92, 0.08);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .kontakt__submit {
    width: 100%;
    justify-content: center;
    padding: 1rem;
    font-size: 1rem;
    margin-top: 0.25rem;
  }

  @media (max-width: 768px) {
    .kontakt__inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .kontakt__form {
      padding: 1.75rem 1.25rem;
    }
  }

  @media (max-width: 480px) {
    .kontakt__direct {
      flex-direction: column;
    }

    .kontakt__direct .btn {
      justify-content: center;
    }
  }
</style>
