---
const schritte = [
  {
    nr: "1",
    titel: "Beratung",
    text: "Sie kontaktieren uns – wir melden uns innerhalb von 24h und besprechen Ihr Projekt.",
  },
  {
    nr: "2",
    titel: "Planung",
    text: "Wir beraten Sie ganzheitlich und erstellen ein unverbindliches Angebot.",
  },
  {
    nr: "3",
    titel: "Ausführung",
    text: "Wir setzen Ihr Projekt professionell um und halten Sie informiert.",
  },
  {
    nr: "4",
    titel: "Fertigstellung",
    text: "Abnahme, Übergabe und vollständige Dokumentation.",
  },
];
---

<section class="ablauf" id="prozess">
  <div class="container">
    <div class="ablauf__header">
      <p class="section-label">Unser Ablauf</p>
      <h2 class="ablauf__h2">Schritt für Schritt zu Ihrer Lösung</h2>
      <p class="ablauf__sub">Transparent, zuverlässig und ohne Überraschungen.</p>
    </div>

    <div class="ablauf__grid">
      {schritte.map((schritt) => (
        <div class="ablauf__card">
          <div class="ablauf__nr">{schritt.nr}</div>
          <h3 class="ablauf__titel">{schritt.titel}</h3>
          <p class="ablauf__text">{schritt.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .ablauf {
    padding: var(--section-pad);
    background: var(--color-bg-dark);
    color: white;
  }

  .ablauf__header {
    text-align: center;
    max-width: 560px;
    margin: 0 auto 3rem;
  }

  .ablauf__header .section-label {
    color: var(--color-accent);
  }

  .ablauf__h2 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    color: white;
    margin: 0.5rem 0 1rem;
    line-height: 1.25;
  }

  .ablauf__sub {
    color: rgba(255, 255, 255, 0.6);
    font-size: 1rem;
    line-height: 1.7;
  }

  .ablauf__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    position: relative;
  }

  .ablauf__grid::before {
    content: "";
    position: absolute;
    top: 2rem;
    left: calc(12.5% + 1.5rem);
    right: calc(12.5% + 1.5rem);
    height: 2px;
    background: linear-gradient(to right, var(--color-accent), transparent);
    opacity: 0.3;
    pointer-events: none;
  }

  .ablauf__card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius);
    padding: 2rem 1.5rem;
    position: relative;
    transition: background 0.2s;
  }

  .ablauf__card:hover {
    background: rgba(255, 255, 255, 0.08);
  }

  .ablauf__nr {
    width: 3rem;
    height: 3rem;
    background: var(--color-accent);
    color: white;
    font-size: 1.1rem;
    font-weight: 800;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
  }

  .ablauf__titel {
    font-size: 1.1rem;
    font-weight: 700;
    color: white;
    margin-bottom: 0.6rem;
  }

  .ablauf__text {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .ablauf__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .ablauf__grid::before {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .ablauf__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
