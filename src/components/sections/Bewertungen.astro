---
import { business } from "../../data/business";
---

<section class="bewertungen" id="bewertungen">
  <div class="container">
    <div class="bewertungen__header">
      <p class="section-label">Bewertungen</p>
      <h2 class="bewertungen__h2">Das sagen unsere Kunden</h2>
      <p class="bewertungen__sub">
        Echte Stimmen aus {business.adresse.stadt} und Umgebung.
      </p>
    </div>

    <div class="bewertungen__grid">
      {business.bewertungen.map((b) => (
        <div class="bewertungen__card">
          <div class="bewertungen__stars" aria-label={`${b.sterne} von 5 Sternen`}>
            {"★".repeat(b.sterne)}
          </div>
          <blockquote class="bewertungen__quote">
            "{b.text}"
          </blockquote>
          <div class="bewertungen__footer">
            <p class="bewertungen__author">
              {b.name}, <span class="bewertungen__ort">{b.ort}</span>
            </p>
            <span class="bewertungen__badge">{b.quelle} ✓</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .bewertungen {
    padding: var(--section-pad);
    background: var(--color-bg-soft);
  }

  .bewertungen__header {
    text-align: center;
    max-width: 560px;
    margin: 0 auto 3rem;
  }

  .bewertungen__h2 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    color: var(--color-primary);
    margin: 0.5rem 0 1rem;
    line-height: 1.25;
  }

  .bewertungen__sub {
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.7;
  }

  .bewertungen__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .bewertungen__card {
    background: white;
    border-radius: var(--radius);
    padding: 2rem;
    box-shadow: var(--shadow-card);
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: box-shadow 0.2s;
  }

  .bewertungen__card:hover {
    box-shadow: var(--shadow-card-hover);
  }

  .bewertungen__stars {
    color: var(--color-star);
    font-size: 1.1rem;
    letter-spacing: 0.1em;
  }

  .bewertungen__quote {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--color-text);
    font-style: normal;
    flex: 1;
  }

  .bewertungen__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .bewertungen__author {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .bewertungen__ort {
    font-weight: 400;
    color: var(--color-text-muted);
  }

  .bewertungen__badge {
    font-size: 0.72rem;
    font-weight: 600;
    color: #2d7a4f;
    background: #e8f5ee;
    padding: 0.2rem 0.6rem;
    border-radius: 2rem;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .bewertungen__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
